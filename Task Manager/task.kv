#:import dp kivy.metrics.dp

<TaskManager>:
    FloatLayout:
        # Fullscreen background image
        Image:
            source: 'back.png'
            allow_stretch: True
            keep_ratio: False
            size: root.size
            pos: root.pos

        # Main vertical panel
        BoxLayout:
            orientation: 'vertical'
            size_hint: .9, .9
            pos_hint: {'center_x': .5, 'center_y': .5}
            padding: dp(16)
            spacing: dp(12)
            canvas.before:
                Color:
                    rgba: 0, 0, 0, .5
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [20]

            # Logo at top
            Image:
                source: 'logo.png'
                size_hint: None, None
                size: dp(100), dp(100)
                pos_hint: {'center_x': .5}
            
            # Text input for new tasks
            TextInput:
                id: task_input
                size_hint_y: None
                height: dp(44)
                hint_text: 'Enter new task'
                background_normal: ''
                background_active: ''
                background_color: 1, 1, 1, 1
                foreground_color: 0, 0, 0, 1
                padding: [dp(10), dp(12)]
                font_size: '16sp'

            # Add button
            Button:
                text: 'Add Task'
                size_hint_y: None
                height: dp(44)
                background_color: .2, .6, .86, 1
                color: 1, 1, 1, 1
                on_press: root.add_task()

            # Scrollable task list
            ScrollView:
                bar_width: dp(8)
                scroll_type: ['bars', 'content']
                GridLayout:
                    id: task_grid
                    cols: 1
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: dp(8)
                    padding: dp(4)

<TaskItem>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(44)
    spacing: dp(8)
    padding: dp(8), 0
    canvas.before:
        Color:
            rgba: 1, 1, 1, .2
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [10]

    CheckBox:
        size_hint: None, None
        size: dp(30), dp(30)
        on_active: root.toggle_done(self, self.active)

    Label:
        id: label
        text: root.task_text
        markup: True  
        text_size: self.size
        halign: 'left'
        valign: 'middle'
        color: 1, 1, 1, 1

    Button:
        text: 'Delete'
        size_hint_x: None
        width: dp(60)
        background_color: 1, .3, .3, 1
        color: 1, 1, 1, 1
        on_press: root.delete_task()
